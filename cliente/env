# ==============================
# CONFIGURACION DEL CLIENTE CNS
# ==============================

# Identificador del nodo - debe coincidir con los registrados en la BD
# Opciones: LPZ-01, CBBA-01, SCZ-01, ORU-01, PTS-01, TJA-01, CHQ-01, BEN-01, PND-01
NODE_CODE=LPZ-01

# Servidor central TCP
SERVER_HOST=localhost
SERVER_PORT=5000

# Intervalo de envio de metricas (segundos)
INTERVAL_SECONDS=10

# Tiempo de espera antes de reintentar reconexion (segundos)
RECONNECT_WAIT=5
